        <PAGEOBJECT XPOS="139.686039370079" YPOS="947.245059605648" OwnPage="1" ItemID="1647663790" PTYPE="4" WIDTH="515.905511811024" HEIGHT="136.062992125984" FRTYPE="0" CLIPEDIT="1" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 136.063 L0 136.063 L0 0 Z" copath="M0 0 L515.906 0 L515.906 136.063 L0 136.063 L0 0 Z" gXpos="734.96162992126" gYpos="65.3552958261275" gWidth="515.905511811024" gHeight="76.5346324611132" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="pgzrun expects there to be two functions. First is "/>
                <ITEXT FONT="Lexend Bold" CH="draw"/>
                <ITEXT CH=" which puts all the images on the screen. Add after the HEIGHT line;"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="Create a new variable body and set it to an Actor choosing one of the images from the bodies directory."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Set the position of the body variable to the middle of the screen."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Create the draw function, which will clear the screen and draw the body."/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="139.686039370077" YPOS="944.410444121069" OwnPage="1" ItemID="1647524942" PTYPE="6" WIDTH="36.8504000000004" HEIGHT="31.1808093956448" FRTYPE="0" CLIPEDIT="0" PWIDTH="1.00000017094018" PLINEART="1" TEXTFLOWMODE="1" path="M0 0 L36.8504 0 L36.8504 31.1808 L0 31.1808 L0 0 Z" copath="M0 0 L36.8504 0 L36.8504 31.1808 L0 31.1808 L0 0 Z" gXpos="0" gYpos="0.5" gWidth="36.8503937007874" gHeight="32.1811023622047" LAYER="0"/>
        <PAGEOBJECT XPOS="142.520685523925" YPOS="944.410444121069" OwnPage="1" ItemID="1647627070" PTYPE="4" WIDTH="31.181107692308" HEIGHT="31.1808093956448" FRTYPE="0" CLIPEDIT="0" PWIDTH="1.00000017094018" PCOLOR="White" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L31.1811 0 L31.1811 31.1808 L0 31.1808 L0 0 Z" copath="M0 0 L31.1811 0 L31.1811 31.1808 L0 31.1808 L0 0 Z" gXpos="2.83464566929297" gYpos="0.5" gWidth="36.8503937007874" gHeight="32.1811023622047" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
