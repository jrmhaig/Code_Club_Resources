            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Open the monster.py file in your editor and you will see the code on the right. This contains;"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="An "/>
                <ITEXT FONT="Lexend Bold" CH="import"/>
                <ITEXT CH=" to say we are going to use the "/>
                <ITEXT FONT="Lexend Bold" CH="pgzrun"/>
                <ITEXT CH=" package. This is short for 'PyGame Zero Run' and it is what allows us to draw."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Two constants WIDTH and HEIGHT that tell pgzrun how big to make the screen."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="The command "/>
                <ITEXT FONT="Lexend Bold" CH="pgzrun.go()"/>
                <ITEXT CH=" to tell pgzrun to start. This must be at the end, after everything else."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="This program will run as it is. Try it and see what happens. See what happens if you change the WIDTH and HEIGHT."/>
                <trail PARENT="Paragraph"/>
            </StoryText>
        </PAGEOBJECT>
