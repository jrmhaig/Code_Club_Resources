        <PAGEOBJECT XPOS="431.654543307089" YPOS="967.087614173222" OwnPage="1" ItemID="1647984734" PTYPE="4" WIDTH="218.267716535433" HEIGHT="127.55905511811" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR="Cyan" SHADE="10" PCOLOR2="Black" PLINEART="6" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="2.83464566929134" TEXTRA="2.83464566929134" BEXTRA="2.83464566929134" REXTRA="2.83464566929134" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L218.268 0 L218.268 127.559 L0 127.559 L0 0 Z" copath="M0 0 L218.268 0 L218.268 127.559 L0 127.559 L0 0 Z" gXpos="1026.93013385827" gYpos="85.1978503937012" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="HEIGHT = 500"/>
                <para PARENT="Code"/>
                <para PARENT="Code"/>
                <ITEXT CH="body = Actor('bodies/yellow_d.png')"/>
                <para PARENT="New Code"/>
                <ITEXT CH="body.pos = (400, 250)"/>
                <para PARENT="New Code"/>
                <para PARENT="New Code"/>
                <ITEXT CH="def draw():"/>
                <para PARENT="New Code"/>
                <ITEXT CH="    screen.clear()"/>
