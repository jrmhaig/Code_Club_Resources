        <PAGEOBJECT XPOS="734.961629921258" YPOS="947.245094488183" OwnPage="2" ItemID="1646936302" PTYPE="4" WIDTH="515.905511811024" HEIGHT="121.889763779528" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 121.89 L0 121.89 L0 0 Z" copath="M0 0 L515.906 0 L515.906 121.89 L0 121.89 L0 0 Z" gXpos="139.686039370077" gYpos="65.3553307086624" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="The other function pgzrun wants is "/>
                <ITEXT FONT="Lexend Bold" CH="update"/>
                <ITEXT CH=" and it controls how things move. We will use it to control the monster with the arrow keys. After the draw function add the update function;"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="Test if the left key is pressed."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Change the x position of the body to make it move left."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Do the same to move right."/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
