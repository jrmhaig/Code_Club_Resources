        <PAGEOBJECT XPOS="737.796276075104" YPOS="1386.61517319165" OwnPage="2" ItemID="1647535054" PTYPE="4" WIDTH="31.181107692308" HEIGHT="31.1811000734027" FRTYPE="0" CLIPEDIT="0" PWIDTH="1.00000017094018" PCOLOR="White" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L31.1811 0 L31.1811 31.1811 L0 31.1811 L0 0 Z" copath="M0 0 L31.1811 0 L31.1811 31.1811 L0 31.1811 L0 0 Z" gXpos="-592.440944881888" gYpos="445.53937007874" gWidth="36.8503937007874" gHeight="32.1811023622047" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
