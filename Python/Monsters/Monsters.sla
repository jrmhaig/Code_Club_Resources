        <PAGEOBJECT XPOS="1029.76477952755" YPOS="952.914385826766" OwnPage="2" ItemID="1647295534" PTYPE="4" WIDTH="218.267716535433" HEIGHT="127.55905511811" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR="Cyan" SHADE="10" PCOLOR2="Black" PLINEART="6" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="2.83464566929134" TEXTRA="2.83464566929134" BEXTRA="2.83464566929134" REXTRA="2.83464566929134" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L218.268 0 L218.268 127.559 L0 127.559 L0 0 Z" copath="M0 0 L218.268 0 L218.268 127.559 L0 127.559 L0 0 Z" gXpos="434.489188976373" gYpos="71.0246220472444" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="def draw():"/>
                <para PARENT="Code"/>
                <ITEXT CH="    screen.clear()"/>
                <para PARENT="Code"/>
                <ITEXT CH="    body.draw()"/>
                <para PARENT="Code"/>
                <para PARENT="Code"/>
                <ITEXT CH="def update():"/>
                <para PARENT="New Code"/>
                <ITEXT CH="    if keyboard[keys.LEFT]:"/>
                <para PARENT="New Code"/>
                <ITEXT CH="        body.x -= 5"/>
                <para PARENT="New Code"/>
                <ITEXT CH="    if keyboard[keys.RIGHT]:"/>
                <para PARENT="New Code"/>
                <ITEXT CH="        body.x += 5"/>
                <para PARENT="New Code"/>
                <ITEXT CH="    # Can you move up and down too?"/>
                <para PARENT="New Code"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="746.300212598423" YPOS="1174.01674803149" OwnPage="2" ItemID="1647311886" PTYPE="4" WIDTH="221.102362204724" HEIGHT="68.0314960629921" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR="Green" SHADE="10" PCOLOR2="Black" PLINEART="15" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="2.83464566929134" TEXTRA="2.83464566929134" BEXTRA="2.83464566929134" REXTRA="2.83464566929134" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L221.102 0 L221.102 68.0315 L0 68.0315 L0 0 Z" copath="M0 0 L221.102 0 L221.102 68.0315 L0 68.0315 L0 0 Z" gXpos="746.300212598424" gYpos="292.12698425197" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
