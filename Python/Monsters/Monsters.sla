        <PAGEOBJECT XPOS="374.96162992126" YPOS="1619.05611811024" OwnPage="1" ItemID="1649542990" PTYPE="5" WIDTH="73.7007874015748" HEIGHT="1" FRTYPE="0" CLIPEDIT="0" ROT="2.85235403751408" PWIDTH="1" PCOLOR2="Black" PLINEART="1" path="" endArrowIndex="25" gXpos="339.417326123791" gYpos="1784.85040027908" gWidth="0" gHeight="0" LAYER="0"/>
        <PAGEOBJECT XPOS="374.96162992126" YPOS="1672.91438582678" OwnPage="1" ItemID="1649545790" PTYPE="5" WIDTH="53.8582677165354" HEIGHT="1" FRTYPE="0" CLIPEDIT="0" ROT="345.167646417694" PWIDTH="1" PCOLOR2="Black" PLINEART="1" path="" endArrowIndex="25" gXpos="339.417326123792" gYpos="1838.70866799562" gWidth="0" gHeight="0" LAYER="0"/>
        <PAGEOBJECT XPOS="740.63092125984" YPOS="1497.16635433071" OwnPage="2" ItemID="1649607262" PTYPE="4" WIDTH="507.40157480315" HEIGHT="204.094488188976" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR="Green" SHADE="10" PCOLOR2="Black" PLINEART="15" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="2.83464566929134" TEXTRA="2.83464566929134" BEXTRA="2.83464566929134" REXTRA="2.83464566929134" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L507.402 0 L507.402 204.094 L0 204.094 L0 0 Z" copath="M0 0 L507.402 0 L507.402 204.094 L0 204.094 L0 0 Z" gXpos="740.630921259841" gYpos="615.276590551182" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FONT="Lexend Bold" CH="Troubleshooting tips"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="If your program does not run here are some things to check."/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="Notice that some of the command have brackets ("/>
                <ITEXT FONT="Courier New Regular" CH="()"/>
                <ITEXT CH=") at the end even if there is nothing in them. For example "/>
                <ITEXT FONT="Courier New Regular" CH="screen.clear()"/>
                <ITEXT CH=" and "/>
                <ITEXT FONT="Courier New Regular" CH="body.draw()"/>
                <ITEXT CH="."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="The lines at the start of a block, like an "/>
                <ITEXT FONT="Courier New Regular" CH="if"/>
                <ITEXT CH=" or a "/>
                <ITEXT FONT="Courier New Regular" CH="def"/>
                <ITEXT CH=", must have a colon ("/>
                <ITEXT FONT="Courier New Regular" CH=":"/>
                <ITEXT CH=") at the end. This is how Python knows where the block starts."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="The file names for the images must be exactly right. Check that you are not using capitals when they should be lower case, or if you have added extra spaces."/>
                <para PARENT="Bullet"/>
                <ITEXT FONT="Lexend Bold" CH="Indentation!"/>
                <ITEXT CH=" This is one of the hardest things for someone starting with Python. Make sure every line has exactly the right number of spaces at the start."/>
                <trail PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="734.96162992126" YPOS="774.016748031498" OwnPage="0" ItemID="1649701502" PTYPE="4" WIDTH="515.905511811024" HEIGHT="48.1889763779528" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 48.189 L0 48.189 L0 0 Z" copath="M0 0 L515.906 0 L515.906 48.189 L0 48.189 L0 0 Z" gXpos="734.96162992126" gYpos="774.016748031499" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Something to try:"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="Try changing the "/>
                <ITEXT FONT="Courier New Regular" CH="WIDTH"/>
                <ITEXT CH=" and "/>
                <ITEXT FONT="Courier New Regular" CH="HEIGHT"/>
                <ITEXT CH=". Make them the right screen size for your computer."/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
