                <ITEXT CH="def update():"/>
                <para PARENT="Code"/>
                <ITEXT CH="    if keyboard[keys.LEFT]:"/>
                <para PARENT="Code"/>
                <ITEXT CH="        body.x -= 5"/>
                <para PARENT="Code"/>
                <ITEXT CH="    if keyboard[keys.RIGHT]:"/>
                <para PARENT="Code"/>
                <ITEXT CH="        body.x += 5"/>
                <para PARENT="Code"/>
                <ITEXT CH="    leftEye.pos = (body.x - 35, body.y - 35)"/>
                <para PARENT="New Code"/>
                <ITEXT CH="    rightEye.pos = (body.x + 35, body.y - 35)"/>
                <para PARENT="New Code"/>
            </StoryText>
        </PAGEOBJECT>
