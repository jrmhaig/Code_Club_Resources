            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="1327.40257480316" YPOS="221.260842519685" OwnPage="-1" ItemID="1157029204" PTYPE="2" WIDTH="155.905511811024" HEIGHT="67.9588128407026" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="0.194168036687722" LOCALSCY="0.194168036687722" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="0" RATIO="1" Pagenumber="0" PFILE="Sierpinski-zoom.png" PRFILE="Embedded GIMP built-in sRGB" IRENDER="0" EPROF="Embedded GIMP built-in sRGB" path="M0 0 L155.906 0 L155.906 67.9588 L0 67.9588 L0 0 Z" copath="M0 0 L155.906 0 L155.906 67.9588 L0 67.9588 L0 0 Z" gXpos="1327.40257480316" gYpos="221.260842519685" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="740.630921259838" YPOS="380.001" OwnPage="0" ItemID="1156988660" PTYPE="4" WIDTH="504.566929133858" HEIGHT="53.8582677165354" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR="Green" SHADE="10" PCOLOR2="Black" PLINEART="15" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="2.83464566929134" TEXTRA="2.83464566929134" BEXTRA="2.83464566929134" REXTRA="2.83464566929134" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L504.567 0 L504.567 53.8583 L0 53.8583 L0 0 Z" copath="M0 0 L504.567 0 L504.567 53.8583 L0 53.8583 L0 0 Z" gXpos="740.630921259842" gYpos="380.001" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FONT="Lexend Bold" CH="Note:"/>
                <ITEXT CH=" A "/>
                <ITEXT FONT="Lexend Bold" CH="library"/>
                <ITEXT CH=" is a set of extra commands that you can add for a particular task. This is the same as the extensions in Scratch."/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="The "/>
                <ITEXT FONT="Lexend Bold" CH="turtle graphics"/>
                <ITEXT CH=" library in Python is like the "/>
                <ITEXT FONT="Lexend Bold" CH="pen"/>
                <ITEXT CH=" extension in Scratch."/>
                <para PARENT="Paragraph"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="740.630921259838" YPOS="544.410448818898" OwnPage="0" ItemID="1156980020" PTYPE="4" WIDTH="504.566929133858" HEIGHT="36.8503937007874" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR="Green" SHADE="10" PCOLOR2="Black" PLINEART="15" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="2.83464566929134" TEXTRA="2.83464566929134" BEXTRA="2.83464566929134" REXTRA="2.83464566929134" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L504.567 0 L504.567 36.8504 L0 36.8504 L0 0 Z" copath="M0 0 L504.567 0 L504.567 36.8504 L0 36.8504 L0 0 Z" gXpos="740.630921259842" gYpos="544.410448818898" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="In Python you can add the whole of a library, like turtle graphics, or just pick the commands you want, like choice from the random library."/>
                <para PARENT="Paragraph"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="468.50493700787" YPOS="952.914385826765" OwnPage="1" ItemID="1156942228" PTYPE="4" WIDTH="181.417322834646" HEIGHT="82.2047244094488" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR="Green" SHADE="10" PCOLOR2="Black" PLINEART="15" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="2.83464566929134" TEXTRA="2.83464566929134" BEXTRA="2.83464566929134" REXTRA="2.83464566929134" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L181.417 0 L181.417 82.2047 L0 82.2047 L0 0 Z" copath="M0 0 L181.417 0 L181.417 82.2047 L0 82.2047 L0 0 Z" gXpos="1063.78052755906" gYpos="71.0246220472454" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="This cuts the distance from the turtle to the point in half. Why a half? Actually, this is the secret that makes the famous pattern!"/>
                <trail PARENT="Paragraph"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="556.985351639589" YPOS="1038.80135881591" OwnPage="1" ItemID="1158344724" PTYPE="5" WIDTH="32.2773194132017" HEIGHT="1" FRTYPE="0" CLIPEDIT="0" ROT="103.055247223797" PWIDTH="1" SHADE="0" PCOLOR2="Black" PLINEART="1" path="" endArrowIndex="26" gXpos="677.289149107944" gYpos="1035.61148539819" gWidth="0" gHeight="0" LAYER="0"/>
        <PAGEOBJECT XPOS="145.355330708659" YPOS="1494.33170866142" OwnPage="1" ItemID="1158344116" PTYPE="4" WIDTH="504.566929133858" HEIGHT="68.0314960629921" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR="Green" SHADE="10" PCOLOR2="Black" PLINEART="15" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="2.83464566929134" TEXTRA="2.83464566929134" BEXTRA="2.83464566929134" REXTRA="2.83464566929134" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L504.567 0 L504.567 68.0315 L0 68.0315 L0 0 Z" copath="M0 0 L504.567 0 L504.567 68.0315 L0 68.0315 L0 0 Z" gXpos="740.630921259841" gYpos="612.441944881891" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FONT="Lexend Bold" CH="Notice,"/>
                <ITEXT CH=" nobody tells the turtle where to draw the triangle. It only follows one simple rule: pick a corner at random and move half-way towards it. Somehow, that simple rule creates one of the most famous fractals in mathematics. This is an example of how complicated patterns can grow from very simple rules. "/>
                <trail PARENT="Paragraph"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="1041.10336220472" YPOS="190.079740157481" OwnPage="0" ItemID="1158222196" PTYPE="4" WIDTH="201.259842519685" HEIGHT="99.2125984251969" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR="Green" SHADE="10" PCOLOR2="Black" PLINEART="15" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="2.83464566929134" TEXTRA="2.83464566929134" BEXTRA="2.83464566929134" REXTRA="2.83464566929134" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L201.26 0 L201.26 99.2126 L0 99.2126 L0 0 Z" copath="M0 0 L201.26 0 L201.26 99.2126 L0 99.2126 L0 0 Z" gXpos="1041.10336220473" gYpos="190.079740157481" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="This project will draw a "/>
                <ITEXT FONT="Lexend Bold" CH="fractal."/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="A fractal is a pattern that contains smaller and smaller copies of itself. You can keep zooming in forever and still find the same pattern."/>
                <para PARENT="Paragraph"/>
            </StoryText>
        </PAGEOBJECT>
    </DOCUMENT>
