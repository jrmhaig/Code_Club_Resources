            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Open a new Python program and add the lines on the right."/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="The "/>
                <ITEXT FONT="Courier 10 Pitch Regular" CH="import turtle"/>
                <ITEXT CH=" command says we are going to use all of the turtle graphics commands."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="The "/>
                <ITEXT FONT="Courier 10 Pitch Regular" CH="from random import choice"/>
                <ITEXT CH=" says we are only going to use the choice command from the random library."/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
