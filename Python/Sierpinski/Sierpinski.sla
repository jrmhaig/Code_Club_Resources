        <PAGEOBJECT XPOS="740.630921259838" YPOS="785.355330708664" OwnPage="0" ItemID="1154784036" PTYPE="4" WIDTH="504.566929133858" HEIGHT="36.8503937007874" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR="Green" SHADE="10" PCOLOR2="Black" PLINEART="15" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="2.83464566929134" TEXTRA="2.83464566929134" BEXTRA="2.83464566929134" REXTRA="2.83464566929134" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L504.567 0 L504.567 36.8504 L0 36.8504 L0 0 Z" copath="M0 0 L504.567 0 L504.567 36.8504 L0 36.8504 L0 0 Z" gXpos="740.630921259842" gYpos="785.355330708664" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FONT="Lexend Bold" CH="Note:"/>
                <ITEXT CH=" The "/>
                <ITEXT FONT="Courier 10 Pitch Regular" CH="print"/>
                <ITEXT CH=" commands are just there to show you what is happening. They will be removed in later code examples, and you can remove them too."/>
                <para PARENT="Paragraph"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="139.686039370079" YPOS="944.410413936357" OwnPage="1" ItemID="1154738036" PTYPE="4" WIDTH="515.905511811024" HEIGHT="257.952755905512" FRTYPE="0" CLIPEDIT="1" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 257.953 L0 257.953 L0 0 Z" copath="M0 0 L515.906 0 L515.906 257.953 L0 257.953 L0 0 Z" gXpos="734.96162992126" gYpos="62.5206501568362" gWidth="515.905511811024" gHeight="76.5346324611132" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="We don't want to draw lines, and to draw the Sierpiński triangle we will want to move forward half the distance to the point, not 100 every time."/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="Use "/>
                <ITEXT FONT="Courier 10 Pitch Regular" CH="penup"/>
                <ITEXT CH=" to stop the line being drawn."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Find half the distance from the turtle to the point, and move forward that amount."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Draw a dot when the turtle arrives."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Do this 10 times and see the dotted pattern you get."/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="139.686039370077" YPOS="941.575798451778" OwnPage="1" ItemID="1154796900" PTYPE="6" WIDTH="36.8504000000004" HEIGHT="31.1808093956448" FRTYPE="0" CLIPEDIT="0" PWIDTH="1.00000017094018" PLINEART="1" TEXTFLOWMODE="1" path="M0 0 L36.8504 0 L36.8504 31.1808 L0 31.1808 L0 0 Z" copath="M0 0 L36.8504 0 L36.8504 31.1808 L0 31.1808 L0 0 Z" gXpos="0" gYpos="-2.33464566929134" gWidth="36.8503937007874" gHeight="32.1811023622047" LAYER="0"/>
        <PAGEOBJECT XPOS="142.520685523925" YPOS="941.575798451778" OwnPage="1" ItemID="1154756100" PTYPE="4" WIDTH="31.181107692308" HEIGHT="31.1808093956448" FRTYPE="0" CLIPEDIT="0" PWIDTH="1.00000017094018" PCOLOR="White" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L31.1811 0 L31.1811 31.1808 L0 31.1808 L0 0 Z" copath="M0 0 L31.1811 0 L31.1811 31.1808 L0 31.1808 L0 0 Z" gXpos="2.83464566929297" gYpos="-2.33464566929134" gWidth="36.8503937007874" gHeight="32.1811023622047" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FONTSIZE="24" CH="4"/>
                <trail PARENT="Number"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="306.930133858271" YPOS="950.079740157474" OwnPage="1" ItemID="1155088340" PTYPE="4" WIDTH="345.826771653543" HEIGHT="198.425196850394" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR="Cyan" SHADE="10" PCOLOR2="Black" PLINEART="6" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="2.83464566929134" TEXTRA="2.83464566929134" BEXTRA="2.83464566929134" REXTRA="2.83464566929134" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L345.827 0 L345.827 198.425 L0 198.425 L0 0 Z" copath="M0 0 L345.827 0 L345.827 198.425 L0 198.425 L0 0 Z" gXpos="902.205724409449" gYpos="68.1899763779532" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="import turtle"/>
                <para PARENT="Code"/>
                <ITEXT CH="from random import choice"/>
                <para PARENT="Code"/>
                <para PARENT="Code"/>
                <ITEXT CH="turtle.penup()"/>
                <para PARENT="New Code"/>
                <para PARENT="Code"/>
                <ITEXT CH="point = (100, 100)"/>
                <para PARENT="Code"/>
                <ITEXT CH="for i in range(10):"/>
                <para PARENT="New Code"/>
                <ITEXT CH="    angle = turtle.towards(point)"/>
                <para PARENT="Code"/>
                <ITEXT CH="    turtle.setheading(angle)"/>
                <para PARENT="Code"/>
                <para PARENT="New Code"/>
                <ITEXT CH="    distance = turtle.distance(point) / 2"/>
                <para PARENT="New Code"/>
                <ITEXT CH="    print(&quot;Half the distance to the point is&quot;, distance)"/>
                <para PARENT="New Code"/>
                <para PARENT="New Code"/>
                <ITEXT CH="    turtle.forward(distance)"/>
                <para PARENT="New Code"/>
                <ITEXT CH="    print(&quot;Drawing a new dot ...&quot;)"/>
                <para PARENT="New Code"/>
                <ITEXT CH="    turtle.dot(5)"/>
                <para PARENT="New Code"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="145.355330708659" YPOS="1208.03249606299" OwnPage="1" ItemID="1154888628" PTYPE="4" WIDTH="240.944881889764" HEIGHT="107.716535433071" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR="Green" SHADE="10" PCOLOR2="Black" PLINEART="15" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="2.83464566929134" TEXTRA="2.83464566929134" BEXTRA="2.83464566929134" REXTRA="2.83464566929134" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L240.945 0 L240.945 107.717 L0 107.717 L0 0 Z" copath="M0 0 L240.945 0 L240.945 107.717 L0 107.717 L0 0 Z" gXpos="740.630921259841" gYpos="326.142732283465" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Notice that these two lines"/>
                <para PARENT="Paragraph"/>
                <tab/>
                <ITEXT CH="angle = turtle.towards(point)"/>
                <para PARENT="Code"/>
                <tab/>
                <ITEXT CH="turtle.setheading(angle)"/>
                <para PARENT="Code"/>
                <ITEXT CH="are not new lines but they are now indented with spaces at the start. This is important to make sure they are in the "/>
                <ITEXT FONT="Courier 10 Pitch Regular" CH="for"/>
                <ITEXT CH=" loop."/>
                <para PARENT="Paragraph"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="734.96162992126" YPOS="598.268716535432" OwnPage="0" ItemID="1155202052" PTYPE="4" WIDTH="515.905511811024" HEIGHT="93.5433070866142" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 93.5433 L0 93.5433 L0 0 Z" copath="M0 0 L515.906 0 L515.906 93.5433 L0 93.5433 L0 0 Z" gXpos="734.96162992126" gYpos="598.268716535432" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="First of all,"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="Choose a point on the screen. Later this will be one corner of the triangle."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Then turn the turtle towards that point and move towards it."/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="734.961629921258" YPOS="595.434070829439" OwnPage="0" ItemID="1155454740" PTYPE="6" WIDTH="36.8504000000015" HEIGHT="31.1811000734027" FRTYPE="0" CLIPEDIT="0" PWIDTH="1.00000017094021" PLINEART="1" TEXTFLOWMODE="1" path="M0 0 L36.8504 0 L36.8504 31.1811 L0 31.1811 L0 0 Z" copath="M0 0 L36.8504 0 L36.8504 31.1811 L0 31.1811 L0 0 Z" gXpos="0" gYpos="43.0196850393701" gWidth="36.8503937007874" gHeight="32.1811023622047" LAYER="0"/>
        <PAGEOBJECT XPOS="737.796276075106" YPOS="595.434070829439" OwnPage="0" ItemID="1155412148" PTYPE="4" WIDTH="31.1811076923089" HEIGHT="31.1811000734027" FRTYPE="0" CLIPEDIT="0" PWIDTH="1.00000017094021" PCOLOR="White" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L31.1811 0 L31.1811 31.1811 L0 31.1811 L0 0 Z" copath="M0 0 L31.1811 0 L31.1811 31.1811 L0 31.1811 L0 0 Z" gXpos="2.83464566929297" gYpos="43.0196850393701" gWidth="36.8503937007874" gHeight="32.1811023622047" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FONTSIZE="24" CH="3"/>
                <trail PARENT="Number"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="924.882889763781" YPOS="629.449818897639" OwnPage="0" ItemID="1155610964" PTYPE="4" WIDTH="320.314960629921" HEIGHT="150.236220472441" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR="Cyan" SHADE="10" PCOLOR2="Black" PLINEART="6" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="2.83464566929134" TEXTRA="2.83464566929134" BEXTRA="2.83464566929134" REXTRA="2.83464566929134" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L320.315 0 L320.315 150.236 L0 150.236 L0 0 Z" copath="M0 0 L320.315 0 L320.315 150.236 L0 150.236 L0 0 Z" gXpos="924.88288976378" gYpos="629.449818897639" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="import turtle"/>
                <para PARENT="Code"/>
                <ITEXT CH="from random import choice"/>
                <para PARENT="Code"/>
                <para PARENT="Code"/>
                <ITEXT CH="point = (100, 100)"/>
                <para PARENT="New Code"/>
                <ITEXT CH="angle = turtle.towards(point)"/>
                <para PARENT="New Code"/>
                <ITEXT CH="print(&quot;The angle to the point is&quot;, angle, &quot;degrees&quot;)"/>
                <para PARENT="New Code"/>
                <para PARENT="New Code"/>
                <ITEXT CH="print(&quot;Turning the turtle towards that point ...&quot;)"/>
                <para PARENT="New Code"/>
                <ITEXT CH="turtle.setheading(angle)"/>
                <para PARENT="New Code"/>
                <para PARENT="New Code"/>
                <ITEXT CH="print(&quot;Drawing a line in that direction ...&quot;)"/>
                <para PARENT="New Code"/>
                <ITEXT CH="turtle.forward(100)"/>
                <para PARENT="New Code"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="139.686039370079" YPOS="1321.4182879521" OwnPage="1" ItemID="1155910228" PTYPE="4" WIDTH="515.905511811024" HEIGHT="167.244094488189" FRTYPE="0" CLIPEDIT="1" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 167.244 L0 167.244 L0 0 Z" copath="M0 0 L515.906 0 L515.906 167.244 L0 167.244 L0 0 Z" gXpos="734.96162992126" gYpos="439.528524172583" gWidth="515.905511811024" gHeight="76.5346324611132" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="The final step is to have three corners, and for each dot we will pick a corner to travel toward at random."/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="Create a list of three points."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Each time round the for loop pick a random corner with the "/>
                <ITEXT FONT="Courier 10 Pitch Regular" CH="choice"/>
                <ITEXT CH=" command. This comes from the "/>
                <ITEXT FONT="Courier New Regular" CH="random"/>
                <ITEXT CH=" library."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Make the turtle super fast by setting the speed to 11."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Draw 1000 dots instead of 10."/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="139.686039370077" YPOS="1318.58367246752" OwnPage="1" ItemID="1156061588" PTYPE="6" WIDTH="36.8504000000004" HEIGHT="31.1808093956448" FRTYPE="0" CLIPEDIT="0" PWIDTH="1.00000017094018" PLINEART="1" TEXTFLOWMODE="1" path="M0 0 L36.8504 0 L36.8504 31.1808 L0 31.1808 L0 0 Z" copath="M0 0 L36.8504 0 L36.8504 31.1808 L0 31.1808 L0 0 Z" gXpos="0" gYpos="374.673228346456" gWidth="36.8503937007874" gHeight="32.1811023622047" LAYER="0"/>
        <PAGEOBJECT XPOS="142.520685523925" YPOS="1318.58367246752" OwnPage="1" ItemID="1156085044" PTYPE="4" WIDTH="31.181107692308" HEIGHT="31.1808093956448" FRTYPE="0" CLIPEDIT="0" PWIDTH="1.00000017094018" PCOLOR="White" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L31.1811 0 L31.1811 31.1808 L0 31.1808 L0 0 Z" copath="M0 0 L31.1811 0 L31.1811 31.1808 L0 31.1808 L0 0 Z" gXpos="2.83464566929297" gYpos="374.673228346456" gWidth="36.8503937007874" gHeight="32.1811023622047" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FONTSIZE="24" CH="5"/>
                <trail PARENT="Number"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="139.686039370077" YPOS="1568.03249606299" OwnPage="1" ItemID="1155880468" PTYPE="4" WIDTH="515.905511811024" HEIGHT="136.062992125984" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 136.063 L0 136.063 L0 0 Z" copath="M0 0 L515.906 0 L515.906 136.063 L0 136.063 L0 0 Z" gXpos="139.686039370077" gYpos="686.142732283466" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Some things to try:"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="1000 dots may still not be enough. Try more, or even go on forever."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="The dots can be a bit blobby. Can you work out how to make the dots smaller so that the pattern is clearer?"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Try different corners to make different triangles."/>
                <para PARENT="Bullet"/>
                <ITEXT FONT="Lexend Bold" CH="(Tricky)"/>
                <ITEXT CH=" What happens if you have a different colour for when you go towards each corner? There are different ways to do this!"/>
                <para PARENT="Bullet"/>
                <ITEXT FONT="Lexend Bold" CH="(Very tricky!)"/>
                <ITEXT CH=" You can have more than three corners but the 'secret' halving of the distance needs to be changed to something else. "/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="397.638795275593" YPOS="1216.53643307086" OwnPage="1" ItemID="1155864116" PTYPE="4" WIDTH="255.118110236221" HEIGHT="269.291338582677" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR="Cyan" SHADE="10" PCOLOR2="Black" PLINEART="6" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="2.83464566929134" TEXTRA="2.83464566929134" BEXTRA="2.83464566929134" REXTRA="2.83464566929134" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L255.118 0 L255.118 269.291 L0 269.291 L0 0 Z" copath="M0 0 L255.118 0 L255.118 269.291 L0 269.291 L0 0 Z" gXpos="992.914385826773" gYpos="334.646669291338" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="import turtle"/>
                <para PARENT="Code"/>
                <ITEXT CH="from random import choice"/>
                <para PARENT="Code"/>
                <para PARENT="Code"/>
                <ITEXT CH="turtle.penup()"/>
                <para PARENT="Code"/>
                <ITEXT CH="turtle.speed(11)"/>
                <para PARENT="New Code"/>
                <para PARENT="New Code"/>
                <ITEXT CH="corners = ["/>
                <para PARENT="New Code"/>
                <ITEXT CH="        (-200, -200),"/>
                <para PARENT="New Code"/>
                <ITEXT CH="        (0, 100),"/>
                <para PARENT="New Code"/>
                <ITEXT CH="        (200, -200)"/>
                <para PARENT="New Code"/>
                <ITEXT CH="    ]"/>
                <para PARENT="New Code"/>
                <para PARENT="Code"/>
                <ITEXT CH="for i in range(1000):"/>
                <para PARENT="New Code"/>
                <ITEXT CH="    point = choice(corners)"/>
                <para PARENT="New Code"/>
                <para PARENT="New Code"/>
                <ITEXT CH="    angle = turtle.towards(point)"/>
                <para PARENT="Code"/>
                <ITEXT CH="    turtle.setheading(angle)"/>
                <para PARENT="Code"/>
                <para PARENT="Code"/>
                <ITEXT CH="    distance = turtle.distance(point) / 2"/>
                <para PARENT="Code"/>
                <para PARENT="Code"/>
                <ITEXT CH="    turtle.forward(distance)"/>
                <para PARENT="Code"/>
                <ITEXT CH="    turtle.dot(5)"/>
                <para PARENT="Code"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="139.686039370077" YPOS="1565.1978503937" OwnPage="1" ItemID="1156171844" PTYPE="6" WIDTH="36.8503937007874" HEIGHT="31.1811023622047" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" path="M0 0 L36.8504 0 L36.8504 31.1811 L0 31.1811 L0 0 Z" copath="M0 0 L36.8504 0 L36.8504 31.1811 L0 31.1811 L0 0 Z" gXpos="139.686039370076" gYpos="683.308086614176" gWidth="0" gHeight="0" LAYER="0"/>
        <PAGEOBJECT XPOS="142.520685039368" YPOS="1565.1978503937" OwnPage="1" ItemID="1156130276" PTYPE="4" WIDTH="31.1811023622047" HEIGHT="31.1811023622047" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR="White" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L31.1811 0 L31.1811 31.1811 L0 31.1811 L0 0 Z" copath="M0 0 L31.1811 0 L31.1811 31.1811 L0 31.1811 L0 0 Z" gXpos="142.520685039368" gYpos="683.308086614174" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="6"/>
                <trail PARENT="Number"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="1316.06399212599" YPOS="309.134858267716" OwnPage="-1" ItemID="1156495780" PTYPE="4" WIDTH="515.905511811023" HEIGHT="121.889763779528" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 121.89 L0 121.89 L0 0 Z" copath="M0 0 L515.906 0 L515.906 121.89 L0 121.89 L0 0 Z" gXpos="1316.06399212599" gYpos="309.134858267717" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="A "/>
                <ITEXT FONT="Lexend Bold" CH="fractal"/>
                <ITEXT CH=" is a pattern that keeps repeating as you try to zoom in and never ends."/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="The "/>
                <ITEXT FONT="Lexend Bold" CH="Sierpiński triangle,"/>
                <ITEXT CH=" or "/>
                <ITEXT FONT="Lexend Bold" CH="Sierpiński gasket,"/>
                <ITEXT CH=" is a triangular fractal pattern. This is shown in the picture. If you zoom into the "/>
                <ITEXT FCOLOR="Red" FSHADE="100" CH="red box"/>
                <ITEXT CH=" in the left picture you get the right picture, and you can do this forever."/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="We are going to write a program to make the Sierpiński triangle and it will seem as though we are doing it randomly!"/>
                <trail PARENT="Paragraph"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="1316.06399212599" YPOS="306.300212598425" OwnPage="-1" ItemID="1156668756" PTYPE="6" WIDTH="36.8503937007874" HEIGHT="31.1811023622047" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" path="M0 0 L36.8504 0 L36.8504 31.1811 L0 31.1811 L0 0 Z" copath="M0 0 L36.8504 0 L36.8504 31.1811 L0 31.1811 L0 0 Z" gXpos="1316.06399212599" gYpos="306.300212598425" gWidth="0" gHeight="0" LAYER="0"/>
