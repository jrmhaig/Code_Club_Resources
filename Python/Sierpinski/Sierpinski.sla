        <PAGEOBJECT XPOS="734.96162992126" YPOS="309.134858267716" OwnPage="0" ItemID="1150907732" PTYPE="4" WIDTH="515.905511811023" HEIGHT="62.3622047244095" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 62.3622 L0 62.3622 L0 0 Z" copath="M0 0 L515.906 0 L515.906 62.3622 L0 62.3622 L0 0 Z" gXpos="734.96162992126" gYpos="309.134858267717" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="We are going to write a very small program using random choices. Can random dots really make this beautiful pattern?"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="This project will use the "/>
                <ITEXT FONT="Lexend Bold" CH="turtle graphics"/>
                <ITEXT CH=" library for drawing and the "/>
                <ITEXT FONT="Courier 10 Pitch Regular" CH="choice"/>
                <ITEXT CH=" method from the "/>
                <ITEXT FONT="Lexend Bold" CH="random"/>
                <ITEXT CH=" library that chooses an item from a list at random."/>
                <para PARENT="Paragraph"/>
            </StoryText>
