        </PAGEOBJECT>
        <PAGEOBJECT XPOS="1162.99312598425" YPOS="156.063992125984" OwnPage="0" ItemID="1523427538" PTYPE="2" WIDTH="76.5354330708661" HEIGHT="32.7321348982321" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="0.481354924974001" LOCALSCY="0.481354924974001" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="0" RATIO="1" Pagenumber="0" PFILE="../159px-Remix_3.0.png" IRENDER="0" EMBEDDED="0" path="M0 0 L76.5354 0 L76.5354 32.7321 L0 32.7321 L0 0 Z" copath="M0 0 L76.5354 0 L76.5354 32.7321 L0 32.7321 L0 0 Z" gXpos="1162.99312598425" gYpos="156.063992125984" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="734.96162992126" YPOS="629.449818897638" OwnPage="0" ItemID="1523402434" PTYPE="4" WIDTH="515.905511811024" HEIGHT="167.244094488189" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 167.244 L0 167.244 L0 0 Z" copath="M0 0 L515.906 0 L515.906 167.244 L0 167.244 L0 0 Z" gXpos="734.96162992126" gYpos="629.449818897639" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Frankie needs to be able to jump, but only if the bike is touching the ground. First, create a new variable "/>
                <ITEXT FONT="Lexend Bold" CH="Jump"/>
                <ITEXT CH=" and then add an "/>
                <ITEXT FONT="Lexend Bold" CH="if ... else"/>
                <ITEXT CH=" block;"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="If Frankie is touching the ground (the grey colour) and space is pressed then set the "/>
                <ITEXT FONT="Lexend Bold" CH="Jump"/>
                <ITEXT CH=" variable."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="If Frankie is not touching the ground then fall towards the ground."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Next we need to use the Jump variable to make the bike to up. So if "/>
                <ITEXT FONT="Lexend Bold" CH="Jump"/>
                <ITEXT CH=" is greater than zero;"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="Move the bike upwards."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Reduce "/>
                <ITEXT FONT="Lexend Bold" CH="Jump"/>
                <ITEXT CH=" by one."/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="139.686039370079" YPOS="1454.64666929133" OwnPage="1" ItemID="1523581090" PTYPE="4" WIDTH="515.905511811024" HEIGHT="48.1889763779528" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 48.189 L0 48.189 L0 0 Z" copath="M0 0 L515.906 0 L515.906 48.189 L0 48.189 L0 0 Z" gXpos="734.96162992126" gYpos="572.756905511812" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Finally, play a sound depending on whether Frankie crashes or reaches the end."/>
                <para PARENT="Paragraph"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="139.686039370077" YPOS="1267.56005511811" OwnPage="1" ItemID="1526901282" PTYPE="4" WIDTH="515.905511811024" HEIGHT="121.889763779528" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="3" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 121.89 L0 121.89 L0 0 Z" copath="M0 0 L515.906 0 L515.906 121.89 L0 121.89 L0 0 Z" gXpos="734.96162992126" gYpos="385.670291338581" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FONT="Lexend Bold" CH="Note"/>
                <para PARENT="Paragraph"/>
                <ITEXT FONT="Lexend Bold" CH="Crashed"/>
                <ITEXT CH=" is a special type of variable called a "/>
                <ITEXT FONT="Lexend Bold" CH="flag."/>
                <ITEXT CH=" A "/>
                <ITEXT FONT="Lexend Bold" CH="flag"/>
                <ITEXT CH=" is used to say if something is "/>
                <ITEXT FONT="Lexend Bold" CH="on or off,"/>
                <ITEXT CH=" or if something is "/>
                <ITEXT FONT="Lexend Bold" CH="true or false."/>
                <ITEXT CH=" Think of when you want to ask a question at school. Your hand is like a flag that you can put up if you have a question or down if you do not."/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="In this case, it is showing if Frankie has or has not crashed. Unlike other variables, like time or score, it can only ever be 0 (off or false) or 1 (on or true)."/>
                <para PARENT="Paragraph"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="1035.43407086613" YPOS="300.630921259843" OwnPage="0" ItemID="1523454674" PTYPE="2" WIDTH="212.59842519685" HEIGHT="283.464566929134" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="0.16875" LOCALSCY="0.16875" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" Pagenumber="0" PFILE="frankie-ride.png" IRENDER="0" EMBEDDED="0" path="M0 0 L212.598 0 L212.598 283.465 L0 283.465 L0 0 Z" copath="M0 0 L212.598 0 L212.598 283.465 L0 283.465 L0 0 Z" gXpos="1035.43407086613" gYpos="300.630921259843" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="539.371078740157" YPOS="1412.12698425198" OwnPage="1" ItemID="1523462002" PTYPE="2" WIDTH="113.385826771654" HEIGHT="124.724409448819" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="0.16875" LOCALSCY="0.16875" LOCALX="0" LOCALY="-2553.28083989501" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" Pagenumber="0" PFILE="frankie-end.png" IRENDER="0" EMBEDDED="0" path="M0 0 L113.386 0 L113.386 124.724 L0 124.724 L0 0 Z" copath="M0 0 L113.386 0 L113.386 124.724 L0 124.724 L0 0 Z" gXpos="539.371078740157" gYpos="1412.12698425198" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="139.686039370079" YPOS="1145.67029133857" OwnPage="1" ItemID="1523892498" PTYPE="4" WIDTH="515.905511811024" HEIGHT="93.5433070866142" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 93.5433 L0 93.5433 L0 0 Z" copath="M0 0 L515.906 0 L515.906 93.5433 L0 93.5433 L0 0 Z" gXpos="734.96162992126" gYpos="263.780527559057" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Frankie needs to stop after hitting an object. This can be done simply by modifying the condition on Frankie's "/>
                <ITEXT FONT="Lexend Bold" CH="repeat"/>
                <ITEXT CH=";"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="Check if "/>
                <ITEXT FONT="Lexend Bold" CH="Crashed"/>
                <ITEXT CH=" is 1."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Remember to initialise "/>
                <ITEXT FONT="Lexend Bold" CH="Crashed"/>
                <ITEXT CH=" to 0 before the repeat loop."/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="462.835645669289" YPOS="1148.50493700788" OwnPage="1" ItemID="1523944498" PTYPE="2" WIDTH="189.92125984252" HEIGHT="62.3622047244095" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="0.16875" LOCALSCY="0.16875" LOCALX="0" LOCALY="-436.745406824147" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" Pagenumber="0" PFILE="frankie-check-crash.png" IRENDER="0" EMBEDDED="0" path="M0 0 L189.921 0 L189.921 62.3622 L0 62.3622 L0 0 Z" copath="M0 0 L189.921 0 L189.921 62.3622 L0 62.3622 L0 0 Z" gXpos="462.835645669289" gYpos="1148.50493700788" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="139.686039370079" YPOS="1553.85926771654" OwnPage="1" ItemID="1523951826" PTYPE="4" WIDTH="515.905511811024" HEIGHT="121.889763779528" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 121.89 L0 121.89 L0 0 Z" copath="M0 0 L515.906 0 L515.906 121.89 L0 121.89 L0 0 Z" gXpos="734.96162992126" gYpos="671.96950393701" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="What else can you add? Here are some ideas;"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="When Frankie gets to the end, start again at the top. Put all the obstacles in different places."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Add new obstacles. Maybe something that Frankie needs to ride under instead of jump over."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Make the obstacles move around. For example, the robot could walk left and right."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Something else from your own imagination!"/>
                <trail PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="139.686039370079" YPOS="944.410448818891" OwnPage="1" ItemID="1524168194" PTYPE="4" WIDTH="515.905511811024" HEIGHT="167.244094488189" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 167.244 L0 167.244 L0 0 Z" copath="M0 0 L515.906 0 L515.906 167.244 L0 167.244 L0 0 Z" gXpos="734.96162992126" gYpos="62.5206850393713" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Lets put some obstacles in the way. There are four sprites; a bus, some rocks, a muffin and a robot. Use the "/>
                <ITEXT FONT="Lexend Bold" CH="go to"/>
                <ITEXT CH=" block to place the objects in the right place. You can put them anywhere and here are my suggestions;"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="Bus at x=50, y=116"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Rocks at x=130, y=32"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Muffin at x=-130, y=70"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Robot at x=-75, y=152"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Then create a "/>
                <ITEXT FONT="Lexend Bold" CH="forever"/>
                <ITEXT CH=" loop to check if the object has been hit by Frankie."/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="Create a new variable "/>
                <ITEXT FONT="Lexend Bold" CH="Crashed"/>
                <ITEXT CH=" and set this to 1 when the object has been hit."/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="535.246100606852" YPOS="976.866238978879" OwnPage="1" ItemID="1523854658" PTYPE="2" WIDTH="116.220472440945" HEIGHT="127.55905511811" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="0.16875" LOCALSCY="0.16875" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" Pagenumber="0" PFILE="obstacle.png" IRENDER="0" EMBEDDED="0" path="M0 0 L116.22 0 L116.22 127.559 L0 127.559 L0 0 Z" copath="M0 0 L116.22 0 L116.22 127.559 L0 127.559 L0 0 Z" gXpos="1130.52169115803" gYpos="94.9764751993572" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
