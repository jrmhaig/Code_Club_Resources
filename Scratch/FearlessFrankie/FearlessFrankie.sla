            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="The stage has four platforms and Frankie starts on the top one. Add code to accelerate and brake;"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="Create a variable "/>
                <ITEXT FONT="Lexend Bold" CH="Speed"/>
                <ITEXT CH=" for the speed of the bike."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Use the right arrow to accelerate up to a maximum speed."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Use the left arrow to brake."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Drop down to the next platform after reaching the right of the screen."/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
