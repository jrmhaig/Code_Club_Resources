        <PAGEOBJECT XPOS="260.72540944882" YPOS="1244.88288976378" OwnPage="1" ItemID="709740839" PTYPE="4" WIDTH="385.511811023622" HEIGHT="93.5433070866142" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="3" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L385.512 0 L385.512 93.5433 L0 93.5433 L0 0 Z" copath="M0 0 L385.512 0 L385.512 93.5433 L0 93.5433 L0 0 Z" gXpos="856.001000000002" gYpos="362.99312598425" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FONT="Lexend ExtraBold" CH="You might have wondered ..."/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="In the countdown sprite why did we put the countdown in a "/>
                <ITEXT FONT="Lexend Bold" CH="when I receive message "/>
                <ITEXT FONT="Lexend Regular" CH="block"/>
                <ITEXT CH=" and not the "/>
                <ITEXT FONT="Lexend Bold" CH="when green flag clicked"/>
                <ITEXT CH=" block?"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="It is so that the countdown could be started again in exactly the same way from here."/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
