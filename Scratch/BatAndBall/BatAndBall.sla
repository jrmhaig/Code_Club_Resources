        <PAGEOBJECT XPOS="142.520685039371" YPOS="1162.67816535433" OwnPage="1" ItemID="696805863" PTYPE="2" WIDTH="107.716535433071" HEIGHT="175.748031496063" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="0.16875" LOCALSCY="0.16875" LOCALX="0" LOCALY="-1327.03412073491" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" Pagenumber="0" PFILE="ball-score-and-restart.png" IRENDER="0" EMBEDDED="0" path="M0 0 L107.717 0 L107.717 175.748 L0 175.748 L0 0 Z" copath="M0 0 L107.717 0 L107.717 175.748 L0 175.748 L0 0 Z" gXpos="142.520685039371" gYpos="1162.67816535433" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="139.686039370079" YPOS="1607.71753543308" OwnPage="1" ItemID="696809031" PTYPE="4" WIDTH="515.905511811024" HEIGHT="76.5354330708661" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 76.5354 L0 76.5354 L0 0 Z" copath="M0 0 L515.906 0 L515.906 76.5354 L0 76.5354 L0 0 Z" gXpos="734.96162992126" gYpos="725.827771653546" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="What can you add to the game? Here are some ideas;"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="Make the ball move faster as the game goes on."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Stop the game when one player reaches a certain score, so the game doesn't go on forever!"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Something else from your own imagination!"/>
                <trail PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="139.686039370079" YPOS="944.410448818891" OwnPage="1" ItemID="696840839" PTYPE="4" WIDTH="515.905511811024" HEIGHT="153.070866141732" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 153.071 L0 153.071 L0 0 Z" copath="M0 0 L515.906 0 L515.906 153.071 L0 153.071 L0 0 Z" gXpos="734.96162992126" gYpos="62.5206850393713" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Now to get the ball moving. In the "/>
                <ITEXT FONT="Lexend Bold" CH="ball"/>
                <ITEXT CH=" sprite;"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="move the ball by changing the x and y position depending on the variables "/>
                <ITEXT FONT="Lexend Bold" CH="x direction"/>
                <ITEXT CH=", "/>
                <ITEXT FONT="Lexend Bold" CH="y direction"/>
                <ITEXT CH=" and "/>
                <ITEXT FONT="Lexend Bold" CH="speed"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="if the ball gets to the left or right edge then bounce - change "/>
                <ITEXT FONT="Lexend Bold" CH="x direction"/>
                <ITEXT CH=" so it goes the opposite way"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="if the ball hits one of the players' paddles then bounce - change "/>
                <ITEXT FONT="Lexend Bold" CH="y direction"/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
