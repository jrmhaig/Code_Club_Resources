            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="The starter project has four sprites;"/>
                <para PARENT="Paragraph"/>
                <ITEXT FONT="Lexend Bold" CH="player 1"/>
                <ITEXT CH=" and "/>
                <ITEXT FONT="Lexend Bold" CH="player 2"/>
                <ITEXT CH=" - these are the two bats that the players use and the code will be almost identical in each, but not quite"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="the "/>
                <ITEXT FONT="Lexend Bold" CH="ball"/>
                <ITEXT CH=" that the players try to hit - most of the code will go in this sprite"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="a "/>
                <ITEXT FONT="Lexend Bold" CH="countdown"/>
                <ITEXT CH=" to let the players get ready to play"/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="139.686039370079" YPOS="1344.09548818898" OwnPage="1" ItemID="695870615" PTYPE="4" WIDTH="515.905511811024" HEIGHT="257.952755905512" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 257.953 L0 257.953 L0 0 Z" copath="M0 0 L515.906 0 L515.906 257.953 L0 257.953 L0 0 Z" gXpos="734.96162992126" gYpos="462.205724409449" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FONT="Lexend ExtraBold" CH="Optional (tricky!)"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="You might have noticed that you can &quot;catch&quot; the ball if you hit it with the edge of the paddle. We can fix this with"/>
                <ITEXT FONT="Lexend Bold" CH=" debounce."/>
                <ITEXT CH=" In the script in the "/>
                <ITEXT FONT="Lexend Bold" CH="ball"/>
                <ITEXT CH=" sprite;"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="set the "/>
                <ITEXT FONT="Lexend Bold" CH="debounce"/>
                <ITEXT CH=" variable to zero before the repeat"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="set the "/>
                <ITEXT FONT="Lexend Bold" CH="debounce"/>
                <ITEXT CH=" variable to 5 when it hits the paddle"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="put the check for touching the paddle around an "/>
                <ITEXT FONT="Lexend Bold" CH="if ... else"/>
                <ITEXT CH=" block so that if debounce is greater than 0 it will reduce it instead of checking the collision with the paddle"/>
                <para PARENT="Bullet"/>
                <ITEXT FONT="Lexend ExtraBold" CH="You might be interested ..."/>
                <ITEXT CH=" "/>
                <ITEXT FONT="Lexend Bold" CH="Debounce"/>
                <ITEXT CH=" is used in web pages to stop things happening lots of times if a button is pressed lots of times quickly."/>
                <trail PARENT="Paragraph"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="1162.99312598425" YPOS="156.063992125984" OwnPage="0" ItemID="695747031" PTYPE="2" WIDTH="76.5354330708661" HEIGHT="32.7321348982321" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="0.481354924974001" LOCALSCY="0.481354924974001" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="0" RATIO="1" Pagenumber="0" PFILE="159px-Remix_3.0.png" IRENDER="0" EMBEDDED="0" path="M0 0 L76.5354 0 L76.5354 32.7321 L0 32.7321 L0 0 Z" copath="M0 0 L76.5354 0 L76.5354 32.7321 L0 32.7321 L0 0 Z" gXpos="1162.99312598425" gYpos="156.063992125984" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="734.96162992126" YPOS="572.75690551181" OwnPage="0" ItemID="695757767" PTYPE="4" WIDTH="515.905511811024" HEIGHT="76.5354330708661" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 76.5354 L0 76.5354 L0 0 Z" copath="M0 0 L515.906 0 L515.906 76.5354 L0 76.5354 L0 0 Z" gXpos="734.96162992126" gYpos="572.756905511811" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="The code for "/>
                <ITEXT FONT="Lexend Bold" CH="player 2"/>
                <ITEXT CH=" is almost the same as for player 1 so you can drag the script from player 1 and drop it onto player 2 underneath the stage. Then in "/>
                <ITEXT FONT="Lexend Bold" CH="player 2"/>
                <ITEXT CH=" you need to make a few changes;"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="change "/>
                <ITEXT FONT="Lexend Bold" CH="y"/>
                <ITEXT CH=" in the "/>
                <ITEXT FONT="Lexend Bold" CH="go to"/>
                <ITEXT CH=" block to put the paddle at the top of the screen"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="look at your keyboard and choose two different keys for left and right"/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="139.686039370079" YPOS="1103.15060629921" OwnPage="1" ItemID="696267863" PTYPE="4" WIDTH="515.905511811024" HEIGHT="138.897637795276" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 138.898 L0 138.898 L0 0 Z" copath="M0 0 L515.906 0 L515.906 138.898 L0 138.898 L0 0 Z" gXpos="734.96162992126" gYpos="221.260842519686" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Now to keep score and start again when one of the players misses. The while touching colour loop will stop when the ball hits the top or bottom so after this;"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="hide the ball and play a sound"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="if the ball is at the bottom add one to player 1's score"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="if the ball is at the top add one to player 2's score"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="send a message to start the countdown again"/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="437.323834645669" YPOS="1349.76477952757" OwnPage="1" ItemID="695969895" PTYPE="2" WIDTH="215.433070866142" HEIGHT="184.251968503937" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="0.16875" LOCALSCY="0.16875" LOCALX="0" LOCALY="-1024.6719160105" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" Pagenumber="0" PFILE="ball-debounce.png" IRENDER="0" EMBEDDED="0" path="M0 0 L215.433 0 L215.433 184.252 L0 184.252 L0 0 Z" copath="M0 0 L215.433 0 L215.433 184.252 L0 184.252 L0 0 Z" gXpos="437.323834645669" gYpos="1349.76477952756" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
