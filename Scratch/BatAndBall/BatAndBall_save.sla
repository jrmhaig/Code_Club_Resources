        <PAGEOBJECT XPOS="734.96162992126" YPOS="382.83564566929" OwnPage="0" ItemID="1557483816" PTYPE="4" WIDTH="515.905511811024" HEIGHT="181.417322834646" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 181.417 L0 181.417 L0 0 Z" copath="M0 0 L515.906 0 L515.906 181.417 L0 181.417 L0 0 Z" gXpos="734.96162992126" gYpos="382.835645669291" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="The first thing to do is to let the players control their paddles. In the "/>
                <ITEXT FONT="Lexend Bold" CH="player 1"/>
                <ITEXT CH=" sprite create a new script when the green flag is clicked to;"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="put the paddle in the right place with a go to block - by setting x to 0 and y to -130 the paddle will go to the middle at the bottom of the stage"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="in a forever loop detect if the left and right arrows are pressed and then move the paddle by changing the x"/>
                <para PARENT="Bullet"/>
                <ITEXT FONT="Lexend Bold" CH="Note:"/>
                <ITEXT CH=" The picture on the right only shows you how to move left - you will need to work out how to move right!"/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
