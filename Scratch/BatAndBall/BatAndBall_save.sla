            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="The starter project has four sprites;"/>
                <para PARENT="Paragraph"/>
                <ITEXT FONT="Lexend Bold" CH="player 1"/>
                <ITEXT CH=" and "/>
                <ITEXT FONT="Lexend Bold" CH="player 2"/>
                <ITEXT CH=" - these are the two bats that the players use and the code will be almost identical in each, but not quite"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="the "/>
                <ITEXT FONT="Lexend Bold" CH="ball"/>
                <ITEXT CH=" that the players try to hit - most of the code will go in this sprite"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="a "/>
                <ITEXT FONT="Lexend Bold" CH="countdown"/>
                <ITEXT CH=" to let the players get ready to play"/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="139.686039370079" YPOS="1168.34745669291" OwnPage="1" ItemID="1557871352" PTYPE="4" WIDTH="515.905511811024" HEIGHT="48.1889763779528" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 48.189 L0 48.189 L0 0 Z" copath="M0 0 L515.906 0 L515.906 48.189 L0 48.189 L0 0 Z" gXpos="734.96162992126" gYpos="286.457692913387" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="The tennis ball needs to fly around."/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="Add code to the "/>
                <ITEXT FONT="Lexend Bold" CH="when I start as a clone"/>
                <ITEXT CH=" script to make keep gliding to random places."/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="1162.99312598425" YPOS="156.063992125984" OwnPage="0" ItemID="1558125656" PTYPE="2" WIDTH="76.5354330708661" HEIGHT="32.7321348982321" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="0.481354924974001" LOCALSCY="0.481354924974001" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="0" RATIO="1" Pagenumber="0" PFILE="159px-Remix_3.0.png" IRENDER="0" EMBEDDED="0" path="M0 0 L76.5354 0 L76.5354 32.7321 L0 32.7321 L0 0 Z" copath="M0 0 L76.5354 0 L76.5354 32.7321 L0 32.7321 L0 0 Z" gXpos="1162.99312598425" gYpos="156.063992125984" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="734.96162992126" YPOS="572.75690551181" OwnPage="0" ItemID="1558120712" PTYPE="4" WIDTH="515.905511811024" HEIGHT="76.5354330708661" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 76.5354 L0 76.5354 L0 0 Z" copath="M0 0 L515.906 0 L515.906 76.5354 L0 76.5354 L0 0 Z" gXpos="734.96162992126" gYpos="572.756905511811" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="The code for "/>
                <ITEXT FONT="Lexend Bold" CH="player 2"/>
                <ITEXT CH=" is almost the same as for player 1 so you can drag the script from player 1 and drop it onto player 2 underneath the stage. Then in "/>
                <ITEXT FONT="Lexend Bold" CH="player 2"/>
                <ITEXT CH=" you need to make a few changes;"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="change "/>
                <ITEXT FONT="Lexend Bold" CH="y"/>
                <ITEXT CH=" in the "/>
                <ITEXT FONT="Lexend Bold" CH="go to"/>
                <ITEXT CH=" block to put the paddle at the top of the screen"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="look at your keyboard and choose two different keys for left and right"/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="139.686039370079" YPOS="1063.46556692913" OwnPage="1" ItemID="1558281672" PTYPE="4" WIDTH="515.905511811024" HEIGHT="93.5433070866142" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 93.5433 L0 93.5433 L0 0 Z" copath="M0 0 L515.906 0 L515.906 93.5433 L0 93.5433 L0 0 Z" gXpos="734.96162992126" gYpos="181.575803149607" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Right now the game is too easy. Let's make it more challenging. Some flying tennis balls will make it harder. The "/>
                <ITEXT FONT="Lexend Bold" CH="tennis ball"/>
                <ITEXT CH=" sprite also has two scripts; when the green flag is clicked and when starting as a clone."/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="Add code to the "/>
                <ITEXT FONT="Lexend Bold" CH="when green flag is clicked"/>
                <ITEXT CH=" script to make a new tennis ball appear every 10 seconds."/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="485.512811023621" YPOS="1165.51281102363" OwnPage="1" ItemID="1558307448" PTYPE="2" WIDTH="119.055118110236" HEIGHT="102.047244094488" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="0.16875" LOCALSCY="0.16875" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" Pagenumber="0" PFILE="tennis-ball-move.png" IRENDER="0" EMBEDDED="0" path="M0 0 L119.055 0 L119.055 102.047 L0 102.047 L0 0 Z" copath="M0 0 L119.055 0 L119.055 102.047 L0 102.047 L0 0 Z" gXpos="485.512811023621" gYpos="1165.51281102362" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="1120.47344094487" YPOS="368.662417322835" OwnPage="0" ItemID="1558300440" PTYPE="2" WIDTH="127.55905511811" HEIGHT="209.763779527559" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="0.16875" LOCALSCY="0.16875" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" Pagenumber="0" PFILE="bat_movement.png" IRENDER="0" EMBEDDED="0" path="M0 0 L127.559 0 L127.559 209.764 L0 209.764 L0 0 Z" copath="M0 0 L127.559 0 L127.559 209.764 L0 209.764 L0 0 Z" gXpos="1120.47344094487" gYpos="368.662417322835" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="562.048244094488" YPOS="1057.79627559055" OwnPage="1" ItemID="1558458280" PTYPE="2" WIDTH="90.7086614173228" HEIGHT="133.228346456693" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="0.16875" LOCALSCY="0.16875" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" Pagenumber="0" PFILE="tennis-ball-clone.png" IRENDER="0" EMBEDDED="0" path="M0 0 L90.7087 0 L90.7087 133.228 L0 133.228 L0 0 Z" copath="M0 0 L90.7087 0 L90.7087 133.228 L0 133.228 L0 0 Z" gXpos="562.048244094488" gYpos="1057.79627559055" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="139.686039370079" YPOS="1349.76477952755" OwnPage="1" ItemID="1558446152" PTYPE="4" WIDTH="515.905511811024" HEIGHT="93.5433070866142" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 93.5433 L0 93.5433 L0 0 Z" copath="M0 0 L515.906 0 L515.906 93.5433 L0 93.5433 L0 0 Z" gXpos="734.96162992126" gYpos="467.875015748031" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="We will end the game when the number of mice gets too big. This stops the game getting out of control."/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="In the Message sprite add code to check when there are too many mice."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="When this happens, show the message and stop all the other scripts."/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="139.686039370079" YPOS="1451.81202362205" OwnPage="1" ItemID="1558609640" PTYPE="4" WIDTH="515.905511811024" HEIGHT="93.5433070866142" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 93.5433 L0 93.5433 L0 0 Z" copath="M0 0 L515.906 0 L515.906 93.5433 L0 93.5433 L0 0 Z" gXpos="734.96162992126" gYpos="569.92225984252" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="What can you add to the game? Here are some ideas;"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="Keep score of how many mice the cat has caught."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Make the mice move at different speeds."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Make the new mice appear at random instead of every 2 seconds."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Make the tennis balls disappear when they hit the cat."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Something else from your own imagination!"/>
                <trail PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="139.686039370079" YPOS="944.410448818891" OwnPage="1" ItemID="1558650120" PTYPE="4" WIDTH="515.905511811024" HEIGHT="107.716535433071" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 107.717 L0 107.717 L0 0 Z" copath="M0 0 L515.906 0 L515.906 107.717 L0 107.717 L0 0 Z" gXpos="734.96162992126" gYpos="62.5206850393713" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Now to get the ball moving. In the "/>
                <ITEXT FONT="Lexend Bold" CH="ball"/>
                <ITEXT CH=" sprite;"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="move the ball by changing the x and y position depending on the variables "/>
                <ITEXT FONT="Lexend Bold" CH="x direction"/>
                <ITEXT CH=", "/>
                <ITEXT FONT="Lexend Bold" CH="y direction"/>
                <ITEXT CH=" and "/>
                <ITEXT FONT="Lexend Bold" CH="speed"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="if the ball gets to the left or right edge then bounce - change x direction from -1 to 1 or 1 to -1"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="if the ball hits one of the players' paddles then boundmove the ball by changing the x and y position depending on the variables "/>
                <ITEXT FONT="Lexend Bold" CH="x direction"/>
                <ITEXT CH=", "/>
                <ITEXT FONT="Lexend Bold" CH="y direction"/>
                <ITEXT CH=" and "/>
                <ITEXT FONT="Lexend Bold" CH="speed"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="if the ball gets to the left or right edge then bounce - change x direction from -1 to 1 or 1 to -1"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="if the ball hits one of the players' paddles then bound"/>
                <para PARENT="Bullet"/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
