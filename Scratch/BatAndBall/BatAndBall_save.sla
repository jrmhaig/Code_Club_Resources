        <PAGEOBJECT XPOS="301.260842519685" YPOS="1551.02462204725" OwnPage="1" ItemID="1559523384" PTYPE="2" WIDTH="198.425196850394" HEIGHT="132.283464566929" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="0.129183070866142" LOCALSCY="0.129183070866142" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="0" RATIO="1" Pagenumber="0" PFILE="CatAndMouse-exhausted.png" IRENDER="0" EMBEDDED="0" path="M0 0 L198.425 0 L198.425 132.283 L0 132.283 L0 0 Z" copath="M0 0 L198.425 0 L198.425 132.283 L0 132.283 L0 0 Z" gXpos="301.260842519685" gYpos="1551.02462204725" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="734.96162992126" YPOS="654.96162992126" OwnPage="0" ItemID="1559507640" PTYPE="4" WIDTH="515.905511811024" HEIGHT="167.244094488189" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 167.244 L0 167.244 L0 0 Z" copath="M0 0 L515.906 0 L515.906 167.244 L0 167.244 L0 0 Z" gXpos="734.96162992126" gYpos="654.961629921261" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Next, the "/>
                <ITEXT FONT="Lexend Bold" CH="countdown"/>
                <ITEXT CH=" sprite will let the players get ready."/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="At the very start, when the green flag is clicked;"/>
                <para PARENT="Paragraph"/>
                <ITEXT FONT="Lexend Bold" CH="broadcast"/>
                <ITEXT CH=" the 'Countdown' message to make the countdown start"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="And then, in the "/>
                <ITEXT FONT="Lexend Bold" CH="when I receive Countdown"/>
                <ITEXT CH=" block;"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="show the number 3 costume"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="three times, wait for a second and then show the next number costume"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="after this, hide the countdown and broadcast a Start message to tell the ball to go"/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
