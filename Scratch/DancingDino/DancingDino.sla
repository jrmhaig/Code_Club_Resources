        <PAGEOBJECT XPOS="550.70966141732" YPOS="1188.18997637795" OwnPage="1" ItemID="997369693" PTYPE="2" WIDTH="102.047244094488" HEIGHT="48.1889763779528" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="0.1875" LOCALSCY="0.1875" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" Pagenumber="0" PFILE="show-button.png" IRENDER="0" EMBEDDED="0" path="M0 0 L102.047 0 L102.047 48.189 L0 48.189 L0 0 Z" copath="M0 0 L102.047 0 L102.047 48.189 L0 48.189 L0 0 Z" gXpos="550.70966141732" gYpos="1188.18997637795" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="139.686039370079" YPOS="1247.71753543306" OwnPage="1" ItemID="984191389" PTYPE="4" WIDTH="515.905511811024" HEIGHT="167.244094488189" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 167.244 L0 167.244 L0 0 Z" copath="M0 0 L515.906 0 L515.906 167.244 L0 167.244 L0 0 Z" gXpos="734.96162992126" gYpos="365.827771653544" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="You may have been wondering why the button is a number '1'. This is because you can now add more buttons to play different music. You will need to;"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="Create new buttons - the sprites of these numbers are all called 'Glow'"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Each new button needs all the scripts of the first button adjusted to appear in different places and send different messages"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="The background needs new music - look in the 'Loops' section of the sounds"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="For each button and each sound the background needs a new script to listen for the message and play the right music"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Each song may need a different 'beat' value - set the 'beat' variable in each script and try different values until the dinosaur dances in time"/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
