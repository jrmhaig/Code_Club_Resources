        <PAGEOBJECT XPOS="734.96162992126" YPOS="428.189976377952" OwnPage="0" ItemID="973550173" PTYPE="4" WIDTH="515.905511811024" HEIGHT="107.716535433071" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 107.717 L0 107.717 L0 0 Z" copath="M0 0 L515.906 0 L515.906 107.717 L0 107.717 L0 0 Z" gXpos="734.96162992126" gYpos="428.189976377953" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Next, in the "/>
                <ITEXT FONT="Lexend Bold" CH="background"/>
                <ITEXT CH=";"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="Listen for the 'song 1' message"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Send the 'dance' message"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Play the music - make sure you use 'until done'"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Send the 'stop dancing' message"/>
                <para PARENT="Bullet"/>
                <ITEXT FONT="Lexend Bold" CH="Note that"/>
                <ITEXT CH=" the two messages we use here already exist so you do not need to create them."/>
                <para PARENT="Paragraph"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="139.686039370079" YPOS="1057.79627559054" OwnPage="1" ItemID="973842125" PTYPE="4" WIDTH="515.905511811024" HEIGHT="48.1889763779528" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 48.189 L0 48.189 L0 0 Z" copath="M0 0 L515.906 0 L515.906 48.189 L0 48.189 L0 0 Z" gXpos="734.96162992126" gYpos="175.906511811025" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Now in the "/>
                <ITEXT FONT="Lexend Bold" CH="background"/>
                <ITEXT CH=";"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="Set the value of the 'beat' variable to fit the music"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="This might take some experimentation!"/>
                <trail PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="1171.49706299212" YPOS="362.993125984252" OwnPage="0" ItemID="973790733" PTYPE="2" WIDTH="73.7007874015748" HEIGHT="48.1889763779528" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="0.1875" LOCALSCY="0.1875" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" Pagenumber="0" PFILE="button-pressed.png" IRENDER="0" EMBEDDED="0" path="M0 0 L73.7008 0 L73.7008 48.189 L0 48.189 L0 0 Z" copath="M0 0 L73.7008 0 L73.7008 48.189 L0 48.189 L0 0 Z" gXpos="1171.49706299212" gYpos="362.993125984252" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="553.544307086614" YPOS="1049.29233858268" OwnPage="1" ItemID="973783469" PTYPE="2" WIDTH="99.2125984251969" HEIGHT="73.7007874015748" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="0.1875" LOCALSCY="0.1875" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" Pagenumber="0" PFILE="set-beat.png" IRENDER="0" EMBEDDED="0" path="M0 0 L99.2126 0 L99.2126 73.7008 L0 73.7008 L0 0 Z" copath="M0 0 L99.2126 0 L99.2126 73.7008 L0 73.7008 L0 0 Z" gXpos="553.544307086614" gYpos="1049.29233858268" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="139.686039370079" YPOS="1145.67029133857" OwnPage="1" ItemID="974062253" PTYPE="4" WIDTH="515.905511811024" HEIGHT="76.5354330708661" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 76.5354 L0 76.5354 L0 0 Z" copath="M0 0 L515.906 0 L515.906 76.5354 L0 76.5354 L0 0 Z" gXpos="734.96162992126" gYpos="263.780527559057" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="When the button is pressed it should disappear until it is ready to be pressed again. The button can do this by listening for the 'dance' and 'stop dancing' messages."/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="Hide when the 'dance' message is received"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Show when the 'stop dancing' message is received"/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="567.717535433069" YPOS="1137.16635433071" OwnPage="1" ItemID="974270093" PTYPE="2" WIDTH="85.0393700787402" HEIGHT="48.1889763779528" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="0.1875" LOCALSCY="0.1875" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" Pagenumber="0" PFILE="hide-button.png" IRENDER="0" EMBEDDED="0" path="M0 0 L85.0394 0 L85.0394 48.189 L0 48.189 L0 0 Z" copath="M0 0 L85.0394 0 L85.0394 48.189 L0 48.189 L0 0 Z" gXpos="567.717535433069" gYpos="1137.16635433071" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="139.686039370079" YPOS="1429.13485826772" OwnPage="1" ItemID="974262829" PTYPE="4" WIDTH="515.905511811024" HEIGHT="76.5354330708661" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 76.5354 L0 76.5354 L0 0 Z" copath="M0 0 L515.906 0 L515.906 76.5354 L0 76.5354 L0 0 Z" gXpos="734.96162992126" gYpos="547.245094488189" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="What else can you add? Here are some ideas;"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="There could be another dinosaur dancing instead (or as well)"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Each piece of music could have a different background"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="The dinosaur could change how it dances when you press different keys"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Something else from your own imagination!"/>
                <trail PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="139.686039370079" YPOS="944.410448818891" OwnPage="1" ItemID="974468349" PTYPE="4" WIDTH="515.905511811024" HEIGHT="93.5433070866142" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 93.5433 L0 93.5433 L0 0 Z" copath="M0 0 L515.906 0 L515.906 93.5433 L0 93.5433 L0 0 Z" gXpos="734.96162992126" gYpos="62.5206850393713" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="The dinosaur is dancing too wildly! We can use a variable to tell it how fast to move to fit the music. First, in the "/>
                <ITEXT FONT="Lexend Bold" CH="dinosaur"/>
                <ITEXT CH=";"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="Create a new variable 'beat' (this must be 'for all sprites')"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Put a wait in the dancing loop for the length of time of 'beat'"/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="535.246100606852" YPOS="948.519782285965" OwnPage="1" ItemID="974193741" PTYPE="2" WIDTH="116.220472440945" HEIGHT="85.0393700787402" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="0.1875" LOCALSCY="0.1875" LOCALX="0" LOCALY="-272.125984251969" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" Pagenumber="0" PFILE="dance-to-the-beat.png" IRENDER="0" EMBEDDED="0" path="M0 0 L116.22 0 L116.22 85.0394 L0 85.0394 L0 0 Z" copath="M0 0 L116.22 0 L116.22 85.0394 L0 85.0394 L0 0 Z" gXpos="1130.52169115803" gYpos="66.6300185064439" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="743.465566929134" YPOS="99.3710787401574" OwnPage="0" ItemID="974219245" PTYPE="2" WIDTH="289.133858267717" HEIGHT="192.755905511811" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="0.188238188976378" LOCALSCY="0.188238188976378" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="0" RATIO="1" Pagenumber="0" PFILE="dancing-dino-banner.png" IRENDER="0" EMBEDDED="0" path="M0 0 L289.134 0 L289.134 192.756 L0 192.756 L0 0 Z" copath="M0 0 L289.134 0 L289.134 192.756 L0 192.756 L0 0 Z" gXpos="743.465566929134" gYpos="99.3710787401574" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="734.96162992126" YPOS="700.315960629921" OwnPage="0" ItemID="974894669" PTYPE="4" WIDTH="515.905511811024" HEIGHT="121.889763779528" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="3" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 121.89 L0 121.89 L0 0 Z" copath="M0 0 L515.906 0 L515.906 121.89 L0 121.89 L0 0 Z" gXpos="734.96162992126" gYpos="700.315960629921" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FONT="Lexend Bold" CH="Why all the messages?"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="Each part - the button, the dinosaur and the background - "/>
                <ITEXT FONT="Lexend Bold" CH="only"/>
                <ITEXT CH=" does it's own thing and then tells other parts to do their thing."/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="The button "/>
                <ITEXT FONT="Lexend Bold" CH="only"/>
                <ITEXT CH=" checks when it is pressed"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="The background "/>
                <ITEXT FONT="Lexend Bold" CH="only"/>
                <ITEXT CH=" plays the music"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="The dinosaur "/>
                <ITEXT FONT="Lexend Bold" CH="only"/>
                <ITEXT CH=" dances"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="This is called "/>
                <ITEXT FONT="Lexend Bold" CH="separation of concerns"/>
                <ITEXT CH=" and it makes it easier to manage a program when it gets more complicated."/>
                <para PARENT="Paragraph"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="1148.8198976378" YPOS="433.859267716535" OwnPage="0" ItemID="974949485" PTYPE="2" WIDTH="99.2125984251969" HEIGHT="85.0393700787402" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="0.1875" LOCALSCY="0.1875" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" Pagenumber="0" PFILE="play-music.png" IRENDER="0" EMBEDDED="0" path="M0 0 L99.2126 0 L99.2126 85.0394 L0 85.0394 L0 0 Z" copath="M0 0 L99.2126 0 L99.2126 85.0394 L0 85.0394 L0 0 Z" gXpos="1148.8198976378" gYpos="433.859267716535" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
