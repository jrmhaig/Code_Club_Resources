        <PAGEOBJECT XPOS="275.749031496063" YPOS="1514.17422834646" OwnPage="1" ItemID="975374973" PTYPE="2" WIDTH="243.779527559055" HEIGHT="162.51968503937" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="0.15871062992126" LOCALSCY="0.15871062992126" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="0" RATIO="1" Pagenumber="0" PFILE="dinosaur-relaxing.png" IRENDER="0" EMBEDDED="0" path="M0 0 L243.78 0 L243.78 162.52 L0 162.52 L0 0 Z" copath="M0 0 L243.78 0 L243.78 162.52 L0 162.52 L0 0 Z" gXpos="275.749031496063" gYpos="1514.17422834646" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="734.96162992126" YPOS="541.575803149605" OwnPage="0" ItemID="987265101" PTYPE="4" WIDTH="515.905511811024" HEIGHT="153.070866141732" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 153.071 L0 153.071 L0 0 Z" copath="M0 0 L515.906 0 L515.906 153.071 L0 153.071 L0 0 Z" gXpos="734.96162992126" gYpos="541.575803149606" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Now in the "/>
                <ITEXT FONT="Lexend Bold" CH="dinosaur"/>
                <ITEXT CH=" sprite;"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="Create a new variable 'dancing' (make it for 'this sprite only')"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Set the 'dancing' variable to 'yes' when the sprite receives the message 'dance'"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Use a "/>
                <ITEXT FONT="Lexend Bold" CH="repeat until"/>
                <ITEXT CH=" to keep changing to the next costume while the 'dancing' variable is 'yes'"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Set the 'dancing' variable to 'no' when the sprite receives the message 'stop dancing' - this will stop the dinosaur changing costumes"/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
