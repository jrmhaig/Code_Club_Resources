            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="In the "/>
                <ITEXT FONT="Lexend Bold" CH="Magic Wand"/>
                <ITEXT CH=" sprite create a script so that it will fly over to where the mouse is clicked. When the wand receives the 'click' message;"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="Play a sound."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Point towards the mouse pointer."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Glide to the mouse pointer."/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
