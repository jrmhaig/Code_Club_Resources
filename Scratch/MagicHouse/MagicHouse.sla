        <PAGEOBJECT XPOS="734.96162992126" YPOS="311.969503937008" OwnPage="0" ItemID="1841452905" PTYPE="4" WIDTH="515.905511811024" HEIGHT="62.3622047244095" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 62.3622 L0 62.3622 L0 0 Z" copath="M0 0 L515.906 0 L515.906 62.3622 L0 62.3622 L0 0 Z" gXpos="734.96162992126" gYpos="311.969503937009" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="In this project you will use the magic wand to cast some spells on other sprites. Each of the sprites has a script to put it in the right place to start."/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="Look in the "/>
                <ITEXT FONT="Lexend Bold" CH="stage"/>
                <ITEXT CH=" and see the script that checks when you click the mouse."/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="When you click the mouse the stage broadcasts the 'click' message."/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="1162.99312598425" YPOS="156.063992125984" OwnPage="0" ItemID="1841551273" PTYPE="2" WIDTH="76.5354330708661" HEIGHT="32.7321348982321" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="0.481354924974001" LOCALSCY="0.481354924974001" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="0" RATIO="1" Pagenumber="0" PFILE="../159px-Remix_3.0.png" IRENDER="0" EMBEDDED="0" path="M0 0 L76.5354 0 L76.5354 32.7321 L0 32.7321 L0 0 Z" copath="M0 0 L76.5354 0 L76.5354 32.7321 L0 32.7321 L0 0 Z" gXpos="1162.99312598425" gYpos="156.063992125984" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="734.96162992126" YPOS="501.890763779526" OwnPage="0" ItemID="1841511257" PTYPE="4" WIDTH="515.905511811024" HEIGHT="153.070866141732" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 153.071 L0 153.071 L0 0 Z" copath="M0 0 L515.906 0 L515.906 153.071 L0 153.071 L0 0 Z" gXpos="734.96162992126" gYpos="501.890763779527" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Now to cast a spell on the toad, who is really the witch in disguise. So in the "/>
                <ITEXT FONT="Lexend Bold" CH="Witch"/>
                <ITEXT CH=" sprite;"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="Check when the sprite is clicked and send the 'click' message."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Wait until the wand touches her and then change the costume to become the witch."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="After changing into the witch she will need to grow and move a bit upwards by changing her y-position. This is done by the "/>
                <ITEXT FONT="Lexend Bold" CH="repeat"/>
                <ITEXT CH=" block. Try different numbers if you want her to grow faster or slower."/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="139.686039370079" YPOS="1077.63879527558" OwnPage="1" ItemID="1841812729" PTYPE="4" WIDTH="515.906" HEIGHT="93.5433070866142" FRTYPE="0" CLIPEDIT="1" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 93.5433 L0 93.5433 L0 0 Z" copath="M0 0 L515.906 0 L515.906 93.5433 L0 93.5433 L0 0 Z" gXpos="139.686039370079" gYpos="1077.63879527558" gWidth="515.906" gHeight="107.717000000002" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Now to get the Ghost to burst out of the bottle. Give it a new script;"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="When it receives the 'ghost move' message go to the potion and show itself."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Grow using the "/>
                <ITEXT FONT="Lexend Bold" CH="repeat block."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Then glide off and fade away using the "/>
                <ITEXT FONT="Lexend Bold" CH="ghost"/>
                <ITEXT CH=" effect."/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="1128.97737795275" YPOS="397.008874015749" OwnPage="0" ItemID="1841567625" PTYPE="2" WIDTH="119.055118110236" HEIGHT="85.0393700787402" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="0.1875" LOCALSCY="0.1875" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" Pagenumber="0" PFILE="wand-move.png" IRENDER="0" EMBEDDED="0" path="M0 0 L119.055 0 L119.055 85.0394 L0 85.0394 L0 0 Z" copath="M0 0 L119.055 0 L119.055 85.0394 L0 85.0394 L0 0 Z" gXpos="1128.97737795275" gYpos="397.008874015749" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="139.686039370079" YPOS="1182.52068503936" OwnPage="1" ItemID="1841581529" PTYPE="4" WIDTH="515.905511811024" HEIGHT="153.070866141732" FRTYPE="0" CLIPEDIT="1" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 153.071 L0 153.071 L0 0 Z" copath="M0 0 L515.906 0 L515.906 153.071 L0 153.071 L0 0 Z" gXpos="139.686039370079" gYpos="1182.52068503936" gWidth="515.905511811024" gHeight="136.062992125986" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="There is a "/>
                <ITEXT FONT="Lexend Bold" CH="Bat"/>
                <ITEXT CH=" hiding at the top. When it is disturbed it will wake up and fly around. The bat will do two things at once. We can do this by broadcasting a message to "/>
                <ITEXT FONT="Lexend Bold" CH="itself."/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="When the bat is clicked, broadcast the 'click' message to the wand."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Then broadcast a new message, 'bat move'."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="After this, create two more scripts when receiving the 'bat move' message;"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="Fly to a few random positions."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Flap the wings and grow. This will look as though it is flying towards you."/>
                <trail PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="207.71753543307" YPOS="1338.4261968504" OwnPage="1" ItemID="1842269881" PTYPE="2" WIDTH="124.724409448819" HEIGHT="119.055118110236" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="0.1875" LOCALSCY="0.1875" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" Pagenumber="0" PFILE="bat-click.png" IRENDER="0" EMBEDDED="0" path="M0 0 L124.724 0 L124.724 119.055 L0 119.055 L0 0 Z" copath="M0 0 L124.724 0 L124.724 119.055 L0 119.055 L0 0 Z" gXpos="207.71753543307" gYpos="1338.4261968504" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="139.686039370079" YPOS="1465.98525196851" OwnPage="1" ItemID="1842227801" PTYPE="4" WIDTH="515.905511811024" HEIGHT="76.5354330708661" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 76.5354 L0 76.5354 L0 0 Z" copath="M0 0 L515.906 0 L515.906 76.5354 L0 76.5354 L0 0 Z" gXpos="734.96162992126" gYpos="584.095488188977" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="What can you add? Here are some ideas;"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="The bat has a sound. Can you use it while it is flying?"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="What can you do with the other costumes the witch and wizard have?"/>
                <para PARENT="Bullet"/>
                <ITEXT CH="The sprites could act differently if other things have been done first."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="What other magical things can you add to the room?"/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="139.686039370079" YPOS="944.410448818891" OwnPage="1" ItemID="1842602649" PTYPE="4" WIDTH="515.905511811024" HEIGHT="121.889763779528" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 121.89 L0 121.89 L0 0 Z" copath="M0 0 L515.906 0 L515.906 121.89 L0 121.89 L0 0 Z" gXpos="734.96162992126" gYpos="62.5206850393713" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="If you look closely you will see some potions on the table. One of them has a ghost inside it! This time, when the "/>
                <ITEXT FONT="Lexend Bold" CH="Potion"/>
                <ITEXT CH=" sprite is clicked it will send a message to another sprite, the "/>
                <ITEXT FONT="Lexend Bold" CH="Ghost"/>
                <ITEXT CH=", to do something. So in the "/>
                <ITEXT FONT="Lexend Bold" CH="Potion"/>
                <ITEXT CH=" sprite;"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="When the sprite is clicked broadcast the 'click' message."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="When the wand touches the potion hide and broadcast a new message, 'ghost move'."/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="526.742163598978" YPOS="948.519782285965" OwnPage="1" ItemID="1842124137" PTYPE="2" WIDTH="124.724409448819" HEIGHT="102.047244094488" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="0.1875" LOCALSCY="0.1875" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" Pagenumber="0" PFILE="potion-clicked.png" IRENDER="0" EMBEDDED="0" path="M0 0 L124.724 0 L124.724 102.047 L0 102.047 L0 0 Z" copath="M0 0 L124.724 0 L124.724 102.047 L0 102.047 L0 0 Z" gXpos="1122.01775415016" gYpos="66.6300185064439" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="539.371078740157" YPOS="1054.96162992126" OwnPage="1" ItemID="1842147337" PTYPE="2" WIDTH="113.385826771654" HEIGHT="235.275590551181" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="0.1875" LOCALSCY="0.1875" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" Pagenumber="0" PFILE="ghost-grow.png" IRENDER="0" EMBEDDED="0" path="M0 0 L113.386 0 L113.386 235.276 L0 235.276 L0 0 Z" copath="M0 0 L113.386 0 L113.386 235.276 L0 235.276 L0 0 Z" gXpos="539.371078740157" gYpos="1054.96162992126" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="743.465566929134" YPOS="99.3710787401574" OwnPage="0" ItemID="1842833145" PTYPE="2" WIDTH="289.133858267717" HEIGHT="192.755905511811" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="0.188238188976378" LOCALSCY="0.188238188976378" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="0" RATIO="1" Pagenumber="0" PFILE="MagicHouse-banner.png" IRENDER="0" EMBEDDED="0" path="M0 0 L289.134 0 L289.134 192.756 L0 192.756 L0 0 Z" copath="M0 0 L289.134 0 L289.134 192.756 L0 192.756 L0 0 Z" gXpos="743.465566929134" gYpos="99.3710787401574" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="734.96162992126" YPOS="669.134858267716" OwnPage="0" ItemID="1842823577" PTYPE="4" WIDTH="515.905511811024" HEIGHT="62.3622047244095" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="3" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 62.3622 L0 62.3622 L0 0 Z" copath="M0 0 L515.906 0 L515.906 62.3622 L0 62.3622 L0 0 Z" gXpos="734.96162992126" gYpos="669.134858267716" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FONT="Lexend ExtraBold" CH="Notice that ..."/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="The same 'click' message is used everywhere."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="It doesn't matter whether the stage or a sprite sends it - the wand reacts the same way."/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="1123.30808661417" YPOS="504.725409448817" OwnPage="0" ItemID="1843105865" PTYPE="2" WIDTH="124.724409448819" HEIGHT="187.086614173228" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="0.1875" LOCALSCY="0.1875" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" Pagenumber="0" PFILE="witch-reveal.png" IRENDER="0" EMBEDDED="0" path="M0 0 L124.724 0 L124.724 187.087 L0 187.087 L0 0 Z" copath="M0 0 L124.724 0 L124.724 187.087 L0 187.087 L0 0 Z" gXpos="1123.30808661417" gYpos="504.725409448817" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
