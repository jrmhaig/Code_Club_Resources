        <PAGEOBJECT XPOS="139.686039370079" YPOS="1236.3789527559" OwnPage="1" ItemID="1802562444" PTYPE="4" WIDTH="515.905511811024" HEIGHT="136.062992125984" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 136.063 L0 136.063 L0 0 Z" copath="M0 0 L515.906 0 L515.906 136.063 L0 136.063 L0 0 Z" gXpos="734.96162992126" gYpos="354.489188976379" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="At the moment the game will go on forever. Let's add three lives and see how long the player can last. Add the script on the right to the stage;"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="Create a new variable Lives and set it to 3 at the start."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Create a new variable Time and set it to 0 at the start."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Adds 1 to the time every second."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Only do this while "/>
                <ITEXT FONT="Lexend Bold" CH="Lives"/>
                <ITEXT CH=" is greater than 0."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Broadcast a message called "/>
                <ITEXT FONT="Lexend Bold" CH="Stop"/>
                <ITEXT CH=". All sprites should listen for this message and stop their other scripts."/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
