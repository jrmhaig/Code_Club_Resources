        <PAGEOBJECT XPOS="734.96162992126" YPOS="484.882889763778" OwnPage="0" ItemID="1794016892" PTYPE="4" WIDTH="515.905511811024" HEIGHT="76.5354330708661" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 76.5354 L0 76.5354 L0 0 Z" copath="M0 0 L515.906 0 L515.906 76.5354 L0 76.5354 L0 0 Z" gXpos="734.96162992126" gYpos="484.882889763779" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Now to create the asteroid storm."/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="This will make a new asteroid as a clone every one second."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="The asteroids are being created, but they are still hidden - we will fix that in the next step."/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="1009.92225984251" YPOS="385.670291338583" OwnPage="0" ItemID="1794072460" PTYPE="2" WIDTH="238.110236220472" HEIGHT="87.8740157480315" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="0.18" LOCALSCY="0.18" LOCALX="0" LOCALY="-267.716535433071" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" Pagenumber="0" PFILE="rocket-controls.png" IRENDER="0" EMBEDDED="0" path="M0 0 L238.11 0 L238.11 87.874 L0 87.874 L0 0 Z" copath="M0 0 L238.11 0 L238.11 87.874 L0 87.874 L0 0 Z" gXpos="1009.92225984251" gYpos="385.670291338583" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="139.686039370079" YPOS="1383.78052755905" OwnPage="1" ItemID="1794160716" PTYPE="4" WIDTH="515.905511811024" HEIGHT="107.716535433071" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 107.717 L0 107.717 L0 0 Z" copath="M0 0 L515.906 0 L515.906 107.717 L0 107.717 L0 0 Z" gXpos="734.96162992126" gYpos="501.890763779527" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Now you need to change "/>
                <ITEXT FONT="Lexend Bold" CH="Lives"/>
                <ITEXT CH=" when the rocket is hit and then make all the other sprites to stop what they are doing when they get the "/>
                <ITEXT FONT="Lexend Bold" CH="Stop"/>
                <ITEXT CH=" message."/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="In the rocket update the script that detects that it has been hit to take 1 off "/>
                <ITEXT FONT="Lexend Bold" CH="Lives"/>
                <ITEXT CH=" each time."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Add the script on the right to "/>
                <ITEXT FONT="Lexend Bold" CH="all"/>
                <ITEXT CH=" sprites so that all their other scripts stop when they get the "/>
                <ITEXT FONT="Lexend Bold" CH="Stop"/>
                <ITEXT CH=" message."/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="553.544307086612" YPOS="1451.81202362205" OwnPage="1" ItemID="1794179292" PTYPE="2" WIDTH="96.3779527559055" HEIGHT="48.1889763779528" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="0.1875" LOCALSCY="0.1875" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" Pagenumber="0" PFILE="stop-sprites.png" IRENDER="0" EMBEDDED="0" path="M0 0 L96.378 0 L96.378 48.189 L0 48.189 L0 0 Z" copath="M0 0 L96.378 0 L96.378 48.189 L0 48.189 L0 0 Z" gXpos="553.544307086612" gYpos="1451.81202362205" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="139.686039370079" YPOS="1511.33958267717" OwnPage="1" ItemID="1794205116" PTYPE="4" WIDTH="515.905511811024" HEIGHT="107.716535433071" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 107.717 L0 107.717 L0 0 Z" copath="M0 0 L515.906 0 L515.906 107.717 L0 107.717 L0 0 Z" gXpos="734.96162992126" gYpos="629.449818897639" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="What can you add to the game? Here are some ideas;"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="There is a laser sprite. You could let the rocket defend itself by blasting the asteroids."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Can you make the game get harder as you go along? Maybe the asteroids can get faster, or appear more often."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="There could be other object that the rocket can catch to do special things."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Something else from your own imagination!"/>
                <trail PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="139.686039370079" YPOS="944.410448818891" OwnPage="1" ItemID="1797685260" PTYPE="4" WIDTH="515.905511811024" HEIGHT="76.5354330708661" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="1" TEXTFLOWMODE="1" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L515.906 0 L515.906 76.5354 L0 76.5354 L0 0 Z" copath="M0 0 L515.906 0 L515.906 76.5354 L0 76.5354 L0 0 Z" gXpos="734.96162992126" gYpos="62.5206850393713" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT CH="Create a new script to check when the rocket hits an asteroid."/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="Use a "/>
                <ITEXT FONT="Lexend Bold" CH="forever"/>
                <ITEXT CH=" loop to keep checking."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Detect when the asteroid is hit and play a sound."/>
                <para PARENT="Bullet"/>
                <ITEXT CH="Flash the rocket  for a couple of seconds while the player can get the rocket to safety."/>
                <para PARENT="Bullet"/>
            </StoryText>
        </PAGEOBJECT>
        <PAGEOBJECT XPOS="743.465566929134" YPOS="99.3710787401574" OwnPage="0" ItemID="1793941164" PTYPE="2" WIDTH="289.133858267717" HEIGHT="192.755905511811" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PLINEART="1" LOCALSCX="0.188238188976378" LOCALSCY="0.188238188976378" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="0" RATIO="1" Pagenumber="0" PFILE="asteroids-banner.png" IRENDER="0" EMBEDDED="0" path="M0 0 L289.134 0 L289.134 192.756 L0 192.756 L0 0 Z" copath="M0 0 L289.134 0 L289.134 192.756 L0 192.756 L0 0 Z" gXpos="743.465566929134" gYpos="99.3710787401574" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1"/>
        <PAGEOBJECT XPOS="751.119110236221" YPOS="567.087614173226" OwnPage="0" ItemID="1794024204" PTYPE="4" WIDTH="331.653543307087" HEIGHT="48.1889763779528" FRTYPE="0" CLIPEDIT="0" PWIDTH="1" PCOLOR2="Black" PLINEART="3" LOCALSCX="1" LOCALSCY="1" LOCALX="0" LOCALY="0" LOCALROT="0" PICART="1" SCALETYPE="1" RATIO="1" COLUMNS="1" COLGAP="0" AUTOTEXT="0" EXTRA="0" TEXTRA="0" BEXTRA="0" REXTRA="0" VAlign="0" FLOP="1" PLTSHOW="0" BASEOF="0" textPathType="0" textPathFlipped="0" path="M0 0 L331.654 0 L331.654 48.189 L0 48.189 L0 0 Z" copath="M0 0 L331.654 0 L331.654 48.189 L0 48.189 L0 0 Z" gXpos="751.119110236221" gYpos="567.087614173226" gWidth="0" gHeight="0" LAYER="0" NEXTITEM="-1" BACKITEM="-1">
            <StoryText>
                <DefaultStyle/>
                <ITEXT FONT="Lexend ExtraBold" CH="Notice"/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="Every asteroid is a "/>
                <ITEXT FONT="Lexend Bold" CH="clone"/>
                <ITEXT CH=" and they all run the same code."/>
                <para PARENT="Paragraph"/>
                <ITEXT CH="This is how we can have lots of asteroids at once."/>
                <trail PARENT="Paragraph"/>
            </StoryText>
        </PAGEOBJECT>
